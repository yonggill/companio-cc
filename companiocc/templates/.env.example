# Companio - Environment Variables
# Copy this file to ~/.companio/.env and fill in your keys

# LLM Provider API Keys (at least one required)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Telegram Bot Token (required for gateway mode)
COMPANIO_CHANNELS__TELEGRAM__BOT_TOKEN=

# Web Search (optional)
BRAVE_API_KEY=
